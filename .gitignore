# --- Python (backend) ------------------------------------------------------
__pycache__/
*.pyc
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml

# --- Node (frontend) ---------------------------------------------------
node_modules/
dist/
*.tsbuildinfo

# --- Environment files -- never commit real secrets/local overrides ----
.env
.env.local
.env.*.local
!.env.example

# --- Terraform -----------------------------------------------------------
# .terraform/ holds downloaded provider binaries (large, regenerated by
# `terraform init`) -- .terraform.lock.hcl is NOT ignored, that one should
# be committed so everyone gets the same provider versions.
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info

# --- OS/editor cruft ---------------------------------------------------
.DS_Store
Thumbs.db
*.swp
